{
  "name": "rayan-tech-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "scripts": {
    "build": "turbo run build",
    "lint": "biome check . && node scripts/check-line-limit.js",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "check-lines": "node scripts/check-line-limit.js",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "db:push": "pnpm --filter @rayan-tech/db db:push",
    "db:generate": "pnpm --filter @rayan-tech/db db:generate",
    "db:seed:products": "pnpm --filter @rayan-tech/db db:seed:products",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "turbo": "^2.10.2",
    "typescript": "^5.8.0"
  }
}
