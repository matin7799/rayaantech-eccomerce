# =============================================================================
# Rayan Tech E-Commerce Monorepo Environment Variables Example
# =============================================================================
# Copy this file to '.env.production' on your VPS and configure production values.
# DO NOT commit the filled '.env.production' file to version control.

# --- 1. Node & Server Run Mode ---
NODE_ENV=production
PORT=3003

# --- 2. Database Connection (PostgreSQL + pgvector) ---
# Note: For Docker Compose, the database service is 'rt-postgres'.
# format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://postgres:postgres_secure_password@rt-postgres:5432/rayaantech

# --- 3. Redis Cache Configuration ---
# Note: For Docker Compose, the Redis service is 'rt-redis'.
REDIS_HOST=rt-redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_password
REDIS_DB=0

# --- 4. Apache Kafka Messaging (SMS & Sync Pipelines) ---
# Note: For Docker Compose, the Kafka broker service is 'rt-kafka:29092'.
KAFKA_BROKERS=rt-kafka:29092
KAFKA_CLIENT_ID=rayan-tech-backend
KAFKA_GROUP_ID=rayan-tech-workers
KAFKAJS_NO_PARTITIONER_WARNING=1

# --- 5. Semantic AI Engine Credentials ---
# Required for VoiceAI transcription and embedding generations:
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Required for AI Consultation text chats (Iranian local RAG pipeline):
AVALAI_API_KEY=aa-your-avalai-api-key-here

# --- 6. AI Rate Limits & Firewalls ---
# Max new AI chat sessions a single IP can initialize per hour
AI_MAX_INITS_PER_HOUR=15
# Initialization limit window in seconds (1 hour)
AI_INIT_WINDOW_SECONDS=3600
# Max messages a single IP can send in a single chat session
AI_MAX_MESSAGES_PER_SESSION=3
# Hard session timeout in seconds (5 minutes)
AI_SESSION_TIMEOUT_SECONDS=300

# --- 7. S3 Cloud Storage (Object Storage) ---
STORAGE_PROVIDER=S3
S3_ACCESS_KEY_ID=your-arvancloud-s3-access-key
S3_SECRET_ACCESS_KEY=your-arvancloud-s3-secret-key
S3_BUCKET=your-production-bucket-name
S3_ENDPOINT=https://s3.ir-thr-at1.arvanstorage.ir
S3_REGION=default
S3_FORCE_PATH_STYLE=false
UPLOAD_DIR=./uploads

# --- 8. Public Network Entry URLs ---
# Absolute URL pointing to your backend Gateway /api/v1 route:
APP_URL=https://yourdomain.com/api/v1
# Absolute URL pointing to your frontend:
FRONTEND_URL=https://yourdomain.com
# API Base Endpoint used by TanStack Start:
API_URL=https://yourdomain.com

# --- 9. SMS Gateway (MelliPayamak shared-line pattern OTP) ---
# Shared-line access token from console.melipayamak.com
# (docs/mellipyamak/send-pattern.md)
MELIPAYAMAK_SHARED_TOKEN=your-melipayamak-shared-token-here
# Legacy fallback token var (used only if MELIPAYAMAK_SHARED_TOKEN is empty)
MELIPAYAMAK_OTP_TOKEN=
# Approved pattern (متن پیشفرض) id whose {0} placeholder receives the OTP code
MELIPAYAMAK_OTP_BODY_ID=455139
# Set to true to print OTP codes to the server console instead of sending SMS
MOCK_SMS=false
# Comma-separated admin numbers to receive alerts for checkout completions:
ADMIN_ALERT_PHONES=09123456789,09121234567

# --- 10. DigiPay Checkout & Installment Installments ---
DIGIPAY_SANDBOX=false
DIGIPAY_CLIENT_ID=your-digipay-client-id
DIGIPAY_CLIENT_SECRET=your-digipay-client-secret
DIGIPAY_USERNAME=your-digipay-username
DIGIPAY_PASSWORD=your-digipay-password
DIGIPAY_MOCK_MODE=false
DIGIPAY_SELLER_ID=1
DIGIPAY_SUPPLIER_ID=1

# --- 11. ZarinPal Gateway Checkout Configurations ---
DEFAULT_PAYMENT_PROVIDER=zarinpal
ZARINPAL_MERCHANT_ID=your-zarinpal-merchant-id-here
ZARINPAL_ACCESS_TOKEN=your-zarinpal-auth-token-here
ZARINPAL_SANDBOX=false
PAYMENT_RESERVATION_TTL_SEC=900
ZARINPAL_MAX_AMOUNT_IRR=4000000000

# --- 12. Outbound Proxy Settings (Overseas Routing) ---
# Used ONLY for OpenAI requests to bypass local Iranian VPS filtering blocks.
# Leave blank to bypass the proxy entirely (direct network connection).
OUTBOUND_PROXY_URL=http://your-proxy-domain-or-ip:port
# Example authenticated proxy: http://user:password@your-proxy-domain-or-ip:port
